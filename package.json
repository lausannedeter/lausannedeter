{
  "name": "lausannedeter-webapp",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build --preset github_pages",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "postbuild": "rimraf docs && cpx \".output/public/**/*\" docs && echo . > docs\\.nojekyll && echo lausannedeter.ch> docs\\CNAME",
    "sync:status": "node scripts/sync-events.js status",
    "sync:push": "node scripts/sync-events.js push",
    "sync:pull": "node scripts/sync-events.js pull"
  },
  "dependencies": {
    "nuxt": "^4.2.2",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "cpx": "^1.5.0",
    "rimraf": "^6.1.2"
  }
}
